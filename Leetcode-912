class Solution {
    public int[] sortArray(int[] nums) {
        PriorityQueue<Integer> pq=new PriorityQueue<>();
        for(int i=0;i<nums.length;i++){
            pq.add(nums[i]);
        }
        int n=pq.size();
        for(int i=0;i<n;i++){
            nums[i]=pq.remove();
        }
        return nums;
   
    }
}
//Time complexity=O(nlogn)
//Auxillary space used =O(n)
