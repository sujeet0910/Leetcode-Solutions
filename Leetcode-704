class Solution {
    public int search(int[] arr, int target) {
        int n=arr.length;
        int lo=0;
        int hi=n-1;

        while(lo<=hi){
            int mid=lo+(hi-lo)/2;
            if(arr[mid]<target) lo=mid+1;
            if(arr[mid]>target) hi=mid-1;
            if(arr[mid]==target)
            return mid;
        }
        return -1;
    }   
}

//Time Complexity: O(log n)
//Auxiliary Space Complexity: O(1) 
